<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="shortcut icon" href="https://telegra.ph/file/5f9f29b29b271ba408000.jpg" type="image/x-icon">
<link href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<title>Mahabub Rahman</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#3b82f6;--blue-dark:#1d4ed8;--blue-light:#eff6ff;--indigo:#6366f1;
  --white:#ffffff;--gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;
  --gray-400:#94a3b8;--gray-500:#64748b;--gray-700:#334155;--gray-900:#0f172a;
  --font:'Poppins',sans-serif;--radius:14px;--radius-lg:20px;--radius-xl:28px;
}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--gray-50);color:var(--gray-700);min-height:100vh;transition:background .4s,color .4s;overflow-x:hidden}
a{text-decoration:none;color:inherit}ul{list-style:none}img{max-width:100%;display:block}

body.dark{
  --white:#1e293b;--gray-50:#0f172a;--gray-100:#1e293b;--gray-200:#334155;
  --gray-400:#64748b;--gray-500:#94a3b8;--gray-700:#cbd5e1;--gray-900:#f1f5f9;
  --blue-light:rgba(59,130,246,.12);
}

/* ── THEME BTN ── */
.theme-btn{
  position:fixed;top:1.2rem;right:1.2rem;z-index:200;
  width:42px;height:42px;border-radius:50%;
  background:rgba(255,255,255,.85);backdrop-filter:blur(12px);
  border:1.5px solid var(--gray-200);display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;color:var(--gray-700);cursor:pointer;
  box-shadow:0 2px 12px rgba(0,0,0,.08);transition:all .3s;
}
.theme-btn:hover{border-color:var(--blue);color:var(--blue);transform:rotate(20deg) scale(1.1)}
body.dark .theme-btn{background:rgba(30,41,59,.85)}

/* ── HERO ── */
.hero{position:relative;height:270px;overflow:hidden;background:linear-gradient(135deg,#1d4ed8 0%,#3b82f6 35%,#6366f1 70%,#8b5cf6 100%)}
.hero-anim{position:absolute;inset:0;overflow:hidden}
.blob{position:absolute;border-radius:50%;filter:blur(65px);opacity:.45;animation:drift 8s ease-in-out infinite alternate}
.blob-1{width:380px;height:380px;background:#93c5fd;top:-110px;left:-70px;animation-delay:0s}
.blob-2{width:290px;height:290px;background:#a5b4fc;top:10px;right:-50px;animation-delay:-3s}
.blob-3{width:210px;height:210px;background:#c4b5fd;bottom:-90px;left:42%;animation-delay:-5s}
@keyframes drift{from{transform:translate(0,0) scale(1)}to{transform:translate(30px,22px) scale(1.12)}}

/* Floating particles */
.particles{position:absolute;inset:0;pointer-events:none}
.particle{
  position:absolute;width:5px;height:5px;border-radius:50%;
  background:rgba(255,255,255,.55);animation:floatUp linear infinite;
}
.particle:nth-child(1){left:10%;width:4px;height:4px;animation-duration:7s;animation-delay:0s}
.particle:nth-child(2){left:25%;width:6px;height:6px;animation-duration:9s;animation-delay:-2s;background:rgba(255,255,255,.35)}
.particle:nth-child(3){left:45%;width:3px;height:3px;animation-duration:6s;animation-delay:-4s}
.particle:nth-child(4){left:65%;width:5px;height:5px;animation-duration:8s;animation-delay:-1s}
.particle:nth-child(5){left:80%;width:4px;height:4px;animation-duration:10s;animation-delay:-3s;background:rgba(255,255,255,.4)}
.particle:nth-child(6){left:90%;width:3px;height:3px;animation-duration:7.5s;animation-delay:-5s}
@keyframes floatUp{0%{transform:translateY(280px) rotate(0deg);opacity:0}10%{opacity:1}90%{opacity:.5}100%{transform:translateY(-20px) rotate(360deg);opacity:0}}

.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.06) 1px,transparent 1px);background-size:36px 36px}

/* ── PAGE ── */
.page{max-width:700px;margin:0 auto;padding:0 1.25rem 4rem;position:relative;z-index:1}

/* ── PROFILE CARD ── */
.profile-card{
  background:var(--white);border-radius:var(--radius-xl);
  padding:0 1.75rem 2rem;
  box-shadow:0 8px 40px rgba(59,130,246,.12),0 2px 8px rgba(0,0,0,.06);
  margin-top:-72px;text-align:center;border:1px solid var(--gray-200);
  animation:cardRise .7s cubic-bezier(.22,1,.36,1) both;animation-delay:.1s;
}
body.dark .profile-card{box-shadow:0 8px 40px rgba(0,0,0,.4)}
@keyframes cardRise{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}

/* ── AVATAR ── */
.avatar-wrap{display:inline-block;margin-top:-52px;margin-bottom:1.1rem;position:relative}

/* Spinning gradient ring */
.avatar-spin{
  width:120px;height:120px;border-radius:50%;padding:3.5px;
  background:conic-gradient(#3b82f6,#6366f1,#8b5cf6,#3b82f6);
  animation:spinRing 4s linear infinite;
  box-shadow:0 8px 28px rgba(99,102,241,.4);
}
@keyframes spinRing{to{transform:rotate(360deg)}}

.avatar-inner{width:100%;height:100%;border-radius:50%;overflow:hidden;border:3.5px solid var(--white);background:var(--gray-100);animation:none}
.avatar-inner img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.avatar-wrap:hover .avatar-inner img{transform:scale(1.07)}

.avatar-status{
  position:absolute;bottom:8px;right:8px;
  width:18px;height:18px;border-radius:50%;
  background:#22c55e;border:3px solid var(--white);
  animation:statusPulse 2.4s ease-in-out infinite;
}
@keyframes statusPulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.45)}60%{box-shadow:0 0 0 7px rgba(34,197,94,0)}}

/* ── STAGGERED TEXT REVEAL ── */
.profile-name{
  font-size:1.55rem;font-weight:800;color:var(--gray-900);
  letter-spacing:-.025em;margin-bottom:.35rem;line-height:1.15;
  animation:fadeUp .55s cubic-bezier(.22,1,.36,1) both;animation-delay:.35s;
}
.profile-role{
  display:inline-flex;align-items:center;gap:.45rem;
  font-size:.75rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;
  color:var(--blue);background:var(--blue-light);
  padding:.3rem 1rem;border-radius:2rem;margin-bottom:1.6rem;
  border:1px solid rgba(59,130,246,.2);
  animation:fadeUp .55s cubic-bezier(.22,1,.36,1) both;animation-delay:.45s;
}
.profile-role i{font-size:.9rem}

/* ── STATS ── */
.stats-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  border:1.5px solid var(--gray-200);border-radius:var(--radius);
  overflow:hidden;margin-bottom:1.6rem;
  animation:fadeUp .55s cubic-bezier(.22,1,.36,1) both;animation-delay:.52s;
}
.stat-cell{
  padding:.9rem .5rem;text-align:center;
  border-right:1.5px solid var(--gray-200);
  transition:background .25s;cursor:default;
}
.stat-cell:last-child{border-right:none}
.stat-cell:hover{background:var(--blue-light)}
body.dark .stat-cell:hover{background:rgba(59,130,246,.1)}
.stat-num{
  font-size:1.2rem;font-weight:800;color:var(--gray-900);
  display:block;line-height:1.2;margin-bottom:.18rem;
}
.stat-desc{font-size:.66rem;font-weight:500;color:var(--gray-400);line-height:1.3}

/* ── SOCIALS ── */
.socials{
  display:flex;justify-content:center;gap:.55rem;margin-bottom:1.6rem;
  animation:fadeUp .55s cubic-bezier(.22,1,.36,1) both;animation-delay:.6s;
}
.soc-btn{
  width:42px;height:42px;border-radius:50%;
  background:var(--gray-100);border:1.5px solid var(--gray-200);
  display:flex;align-items:center;justify-content:center;
  font-size:1.05rem;color:var(--gray-500);transition:all .28s cubic-bezier(.22,1,.36,1);
}
.soc-btn:hover{
  background:var(--blue);border-color:var(--blue);color:#fff;
  transform:translateY(-5px) scale(1.1);
  box-shadow:0 10px 22px rgba(59,130,246,.4);
}

/* ── BUTTONS ── */
.actions{
  display:flex;justify-content:center;gap:.7rem;flex-wrap:wrap;
  animation:fadeUp .55s cubic-bezier(.22,1,.36,1) both;animation-delay:.68s;
}
.btn{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.72rem 1.45rem;border-radius:.75rem;
  font-family:var(--font);font-size:.85rem;font-weight:600;
  cursor:pointer;border:none;transition:all .28s cubic-bezier(.22,1,.36,1);
  position:relative;overflow:hidden;
}
/* Shimmer on primary */
.btn-fill{background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;box-shadow:0 6px 20px rgba(99,102,241,.38)}
.btn-fill::after{
  content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);
  transform:skewX(-20deg);transition:left .5s;
}
.btn-fill:hover::after{left:140%}
.btn-fill:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(99,102,241,.52)}
.btn-fill:active{transform:translateY(0) scale(.97)}

.btn-outline{background:var(--white);color:var(--gray-700);border:1.5px solid var(--gray-200)}
.btn-outline:hover{border-color:var(--blue);color:var(--blue);transform:translateY(-3px);box-shadow:0 6px 20px rgba(59,130,246,.12)}
.btn-outline:active{transform:translateY(0) scale(.97)}

/* ── TABS ── */
.tab-wrap{margin-top:2rem;animation:fadeUp .6s cubic-bezier(.22,1,.36,1) both;animation-delay:.25s}
.tab-bar{
  display:flex;background:var(--white);border:1.5px solid var(--gray-200);
  border-radius:var(--radius);padding:.3rem;gap:.3rem;
  box-shadow:0 2px 12px rgba(0,0,0,.05);margin-bottom:1.75rem;
}
.tab{
  flex:1;padding:.72rem .5rem;border:none;background:transparent;
  font-family:var(--font);font-size:.875rem;font-weight:500;color:var(--gray-400);
  border-radius:.625rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:.4rem;
  transition:all .3s cubic-bezier(.22,1,.36,1);
}
.tab i{font-size:1rem}
.tab:hover{color:var(--gray-700);background:var(--gray-100)}
.tab.active{
  background:linear-gradient(135deg,#3b82f6,#6366f1);
  color:#fff;font-weight:600;
  box-shadow:0 4px 14px rgba(99,102,241,.35);
}

/* ── PANELS ── */
.panel{display:none;animation:panelIn .4s cubic-bezier(.22,1,.36,1) both}
.panel.active{display:block}
@keyframes panelIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* ── PROJECT CARDS ── */
.proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem}
.proj-card{
  background:var(--white);border-radius:var(--radius-lg);overflow:hidden;
  border:1.5px solid var(--gray-200);box-shadow:0 2px 12px rgba(0,0,0,.05);
  transition:all .35s cubic-bezier(.22,1,.36,1);
  animation:fadeUp .5s cubic-bezier(.22,1,.36,1) both;
}
.proj-card:hover{
  transform:translateY(-10px) scale(1.015);
  box-shadow:0 24px 56px rgba(59,130,246,.16);
  border-color:rgba(99,102,241,.3);
}
.proj-thumb{position:relative;aspect-ratio:16/10;overflow:hidden;background:var(--gray-100)}
.proj-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.22,1,.36,1)}
.proj-card:hover .proj-thumb img{transform:scale(1.09)}

.proj-hover{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(15,23,42,.93) 0%,rgba(15,23,42,.15) 55%,transparent 100%);
  display:flex;flex-direction:column;justify-content:flex-end;padding:1.2rem;
  opacity:0;transform:translateY(8px);
  transition:opacity .35s,transform .35s cubic-bezier(.22,1,.36,1);
}
.proj-card:hover .proj-hover{opacity:1;transform:translateY(0)}
.proj-hover-tag{font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#93c5fd;margin-bottom:.25rem}
.proj-hover-title{font-size:1rem;font-weight:700;color:#fff;margin-bottom:.75rem}
.proj-hover-link{
  display:inline-flex;align-items:center;gap:.4rem;
  background:#3b82f6;color:#fff;font-size:.75rem;font-weight:600;
  padding:.42rem .9rem;border-radius:.5rem;width:fit-content;
  transition:all .2s;
}
.proj-hover-link:hover{background:#2563eb;transform:translateX(3px)}

.proj-body{padding:.95rem 1.1rem 1.1rem;display:flex;align-items:center;justify-content:space-between}
.proj-tag{
  font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;
  color:var(--blue);background:var(--blue-light);padding:.22rem .65rem;border-radius:2rem;
  border:1px solid rgba(59,130,246,.2);margin-bottom:.25rem;display:inline-block;
}
.proj-title{font-size:.9rem;font-weight:600;color:var(--gray-900)}
.proj-icon-link{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;
  display:flex;align-items:center;justify-content:center;font-size:.9rem;
  transition:all .28s cubic-bezier(.22,1,.36,1);
  box-shadow:0 4px 10px rgba(99,102,241,.3);
}
.proj-icon-link:hover{box-shadow:0 8px 20px rgba(99,102,241,.5);transform:scale(1.12) rotate(-6deg)}

/* ── SKILLS ── */
.skill-card{
  background:var(--white);border-radius:var(--radius-lg);
  border:1.5px solid var(--gray-200);padding:1.6rem;
  box-shadow:0 2px 12px rgba(0,0,0,.05);
  animation:fadeUp .5s cubic-bezier(.22,1,.36,1) both;
}
.skill-head{display:flex;align-items:center;gap:.65rem;margin-bottom:1.4rem}
.skill-head-icon{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,#3b82f6,#6366f1);
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:1rem;flex-shrink:0;
}
.skill-head-title{font-size:.8rem;font-weight:700;color:var(--gray-900);text-transform:uppercase;letter-spacing:.1em}
.skill-head-line{flex:1;height:1.5px;background:var(--gray-200);border-radius:2px}

.skill-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.7rem}

/* Staggered pill entrance */
.skill-pill{
  display:flex;align-items:center;gap:.65rem;
  padding:.65rem .95rem;border-radius:.75rem;
  background:var(--gray-50);border:1.5px solid var(--gray-200);
  transition:all .3s cubic-bezier(.22,1,.36,1);cursor:default;
  opacity:0;animation:pillIn .5s cubic-bezier(.22,1,.36,1) both;
}
.skill-pill:nth-child(1){animation-delay:.05s}
.skill-pill:nth-child(2){animation-delay:.12s}
.skill-pill:nth-child(3){animation-delay:.19s}
@keyframes pillIn{from{opacity:0;transform:translateY(10px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.skill-pill:hover{
  background:var(--blue-light);border-color:rgba(59,130,246,.4);
  transform:translateY(-3px) scale(1.03);
  box-shadow:0 8px 20px rgba(59,130,246,.12);
}
body.dark .skill-pill:hover{background:rgba(59,130,246,.1)}

.skill-dot{
  width:9px;height:9px;border-radius:50%;
  background:linear-gradient(135deg,#3b82f6,#6366f1);flex-shrink:0;
  animation:dotPop .4s cubic-bezier(.22,1,.36,1) both;
  transition:transform .3s;
}
.skill-pill:hover .skill-dot{transform:scale(1.4)}

.skill-pname{font-size:.84rem;font-weight:600;color:var(--gray-900)}
.skill-plevel{font-size:.67rem;color:var(--gray-400);margin-top:.05rem}

/* ── FOOTER ── */
.footer{text-align:center;padding:1rem 0 2rem;font-size:.73rem;color:var(--gray-400)}
.footer span{color:var(--blue);font-weight:500}

/* ── GLOBAL ANIM UTILS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:.45rem;background:var(--gray-100)}
::-webkit-scrollbar-thumb{background:var(--gray-200);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--gray-400)}

/* ── RESPONSIVE ── */
@media(max-width:480px){
  .hero{height:210px}
  .profile-name{font-size:1.3rem}
  .actions{flex-direction:column;align-items:center}
  .proj-grid{grid-template-columns:1fr}
  .skill-list{grid-template-columns:repeat(2,1fr)}
}
@media(min-width:680px){
  .hero{height:290px}
  .avatar-spin{width:134px;height:134px}
  .avatar-wrap{margin-top:-60px}
}
</style>
</head>
<body>

<button class="theme-btn" id="themeBtn" aria-label="Toggle theme">
  <i class="ri-moon-line" id="themeIcon"></i>
</button>

<!-- Hero -->
<div class="hero">
  <div class="hero-anim">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  <div class="particles">
    <span class="particle"></span><span class="particle"></span>
    <span class="particle"></span><span class="particle"></span>
    <span class="particle"></span><span class="particle"></span>
  </div>
  <div class="hero-grid"></div>
</div>

<!-- Page content -->
<div class="page">

  <div class="profile-card">

    <!-- Spinning avatar ring -->
    <div class="avatar-wrap">
      <div class="avatar-spin">
        <div class="avatar-inner">
          <img src="https://fbpp-api.vercel.app/api/fbpp?uid=100014754734049" alt="Mahabub Rahman">
        </div>
      </div>
      <span class="avatar-status"></span>
    </div>

    <h1 class="profile-name">Mahabub Rahman</h1>
    <div class="profile-role"><i class="ri-terminal-box-line"></i> Hacker &amp; Developer</div>

    <div class="stats-row">
      <div class="stat-cell">
        <span class="stat-num" data-count="80">0%</span>
        <span class="stat-desc">Ugly Face 🤡</span>
      </div>
      <div class="stat-cell">
        <span class="stat-num" data-count="100">0%</span>
        <span class="stat-desc">Pain 😴</span>
      </div>
      <div class="stat-cell">
        <span class="stat-num" data-count="0">0%</span>
        <span class="stat-desc">Perfect Guy</span>
      </div>
    </div>

    <div class="socials">
      <a href="https://www.youtube.com/@Mahabub_Rahman_404" target="_blank" class="soc-btn" title="YouTube"><i class="ri-youtube-line"></i></a>
      <a href="https://www.facebook.com/www.xnxx.com140" target="_blank" class="soc-btn" title="Facebook"><i class="ri-facebook-line"></i></a>
      <a href="https://github.com/MR-MAHABUB-004" target="_blank" class="soc-btn" title="GitHub"><i class="ri-github-line"></i></a>
    </div>

    <div class="actions">
      <a href="https://api.whatsapp.com/send?phone=+8801613356376&text=Assalamu%20Walaikum" target="_blank" class="btn btn-fill">
        <i class="ri-whatsapp-line"></i> Message Me
      </a>
      <a href="https://github.com/MR-MAHABUB-004" target="_blank" class="btn btn-outline">
        <i class="ri-github-line"></i> GitHub
      </a>
    </div>

  </div>

  <!-- Tabs -->
  <div class="tab-wrap">
    <div class="tab-bar">
      <button class="tab active" data-target="projects"><i class="ri-folder-3-line"></i> Projects</button>
      <button class="tab" data-target="skills"><i class="ri-code-s-slash-line"></i> Skills</button>
    </div>

    <!-- Projects panel -->
    <div class="panel active" id="projects">
      <div class="proj-grid">
        <div class="proj-card">
          <div class="proj-thumb">
            <img src="https://i.postimg.cc/VsXSgvGQ/e624bd9b-886d-4530-84e6-c41f5e4bd585.gif" alt="REST API">
            <div class="proj-hover">
              <p class="proj-hover-tag">Web</p>
              <h3 class="proj-hover-title">REST API</h3>
              <a href="https://mahabub-apis.fun" target="_blank" class="proj-hover-link"><i class="ri-link"></i> Visit Site</a>
            </div>
          </div>
          <div class="proj-body">
            <div>
              <span class="proj-tag">Web</span>
              <p class="proj-title">REST API</p>
            </div>
            <a href="https://mahabub-apis.fun" target="_blank" class="proj-icon-link"><i class="ri-external-link-line"></i></a>
          </div>
        </div>
      </div>
    </div>

    <!-- Skills panel -->
    <div class="panel" id="skills">
      <div class="skill-card">
        <div class="skill-head">
          <div class="skill-head-icon"><i class="ri-layout-3-line"></i></div>
          <p class="skill-head-title">Frontend Development</p>
          <div class="skill-head-line"></div>
        </div>
        <div class="skill-list">
          <div class="skill-pill">
            <span class="skill-dot"></span>
            <div><p class="skill-pname">HTML</p><p class="skill-plevel">Basic</p></div>
          </div>
          <div class="skill-pill">
            <span class="skill-dot"></span>
            <div><p class="skill-pname">CSS</p><p class="skill-plevel">Basic</p></div>
          </div>
          <div class="skill-pill">
            <span class="skill-dot"></span>
            <div><p class="skill-pname">JavaScript</p><p class="skill-plevel">Basic</p></div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <footer class="footer">
    <p>&#169; <span>Mahabub Rahman</span> &mdash; All rights reserved</p>
  </footer>

</div>

<script src="https://unpkg.com/scrollreveal"></script>
<script>
/* ── Tabs with panel animation ── */
document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));
    t.classList.add('active');
    const panel=document.getElementById(t.dataset.target);
    panel.classList.add('active');
    /* re-trigger pill animations on skills tab */
    if(t.dataset.target==='skills'){
      panel.querySelectorAll('.skill-pill').forEach((p,i)=>{
        p.style.animation='none';
        requestAnimationFrame(()=>{ p.style.animation=`pillIn .5s cubic-bezier(.22,1,.36,1) ${i*.07}s both`; });
      });
    }
  });
});

/* ── Theme ── */
const btn=document.getElementById('themeBtn'),icon=document.getElementById('themeIcon');
let dark=localStorage.getItem('theme')==='dark';
const setTheme=()=>{
  document.body.classList.toggle('dark',dark);
  icon.className=dark?'ri-sun-line':'ri-moon-line';
};
setTheme();
btn.addEventListener('click',()=>{ dark=!dark; localStorage.setItem('theme',dark?'dark':'light'); setTheme(); });

/* ── Count-up animation for stats ── */
function countUp(el){
  const target=parseInt(el.dataset.count,10);
  if(target===0){ el.textContent='0%'; return; }
  let start=0;
  const step=target/40;
  const timer=setInterval(()=>{
    start=Math.min(start+step,target);
    el.textContent=Math.round(start)+'%';
    if(start>=target) clearInterval(timer);
  },28);
}
/* Trigger after card animates in */
setTimeout(()=>{
  document.querySelectorAll('.stat-num[data-count]').forEach(countUp);
},600);

/* ── Scroll reveal ── */
const sr=ScrollReveal({origin:'bottom',distance:'28px',duration:700,delay:100,easing:'cubic-bezier(.22,1,.36,1)'});
sr.reveal('.tab-wrap',{delay:180});
sr.reveal('.proj-card',{delay:220,interval:120});
sr.reveal('.skill-card',{delay:180});
</script>
</body>
</html>
